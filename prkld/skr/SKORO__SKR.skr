}//*/

// ============================================================================
// 5. ТОПОЛОГИЯ ИНТЕРФЕЙСА (@elmnt) — Дерево элементов макета (Приоритет 4.5)
// ============================================================================
@elmnt {

	krb:elmnt_svz_1 (
		//elmnt_obrz: main_viewport
