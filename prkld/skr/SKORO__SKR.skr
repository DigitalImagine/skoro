			//cvt_osn:		&cvt_osn
			// НИЖЕ ПРИМЕР ОТМЕТА МУСОРНЫХ "ПРОБЕЛЬНЫХ" СИМВОЛОВ
			
			// Прямая связь с ОЗУ: цвет текста мгновенно меняется вслед за &user_cvt
			cvt_osn: &user_cvt	// СПЕЦИАЛЬНЫЙ ПРИМЕР НЕСООТВЕТСТВИЯ ТИПА (ПРОВОКАЦИЯ ОШИБА КОМПИЛЯЦИИ)
